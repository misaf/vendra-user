{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "misaf/vendra-user",
    "description": "Comprehensive user management module with profiles, authentication, media handling and multi-tenant support",
    "type": "vendra-module",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filamentphp",
        "user"
    ],
    "authors": [
        {
            "name": "Ehsan Mahmoodi",
            "email": "misaf.1990@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "laravel/pennant": "^1.19",
        "misaf/vendra-activity-log": "dev-master",
        "misaf/vendra-tenant": "^12.0",
        "staudenmeir/belongs-to-through": "^2.16.4",
        "mokhosh/filament-jalali": "5.1",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "filament/filament": "^4.0|^5.0",
        "larastan/larastan": "^3.9.1",
        "laravel/boost": "^2.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.3",
        "pestphp/pest": "^4.3.1",
        "pestphp/pest-plugin-laravel": "^4.0",
        "orchestra/testbench": "^10.0"
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "pest"
    },
    "autoload": {
        "psr-4": {
            "Misaf\\VendraUser\\": "src/",
            "Misaf\\VendraUser\\Tests\\": "tests/",
            "Misaf\\VendraUser\\Database\\Factories\\": "database/factories/",
            "Misaf\\VendraUser\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Misaf\\VendraUser\\UserServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
