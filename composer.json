{
	"name": "misaf/vendra-user",
	"description": "Comprehensive user management module with profiles, authentication, media handling and multi-tenant support",
	"license": "MIT",
	"type": "vendra-module",
	"keywords": [
		"laravel",
		"filamentphp",
		"user"
	],
	"authors": [
		{
			"name": "Ehsan Mahmoodi",
			"email": "misaf.1990@gmail.com",
			"role": "Developer"
		}
	],
	"require": {
		"php": "^8.2",
		"filament/filament": "^5.0",
		"illuminate/support": "^12.0 || ^13.0",
		"laravel/pennant": "^1.19",
		"misaf/vendra-activity-log": "dev-master",
		"misaf/vendra-tenant": "dev-master",
		"mokhosh/filament-jalali": "5.0",
		"spatie/laravel-package-tools": "^1.0",
		"staudenmeir/belongs-to-through": "^2.0"
	},
	"require-dev": {
		"fakerphp/faker": "^1.0",
		"larastan/larastan": "^3.0",
		"laravel/boost": "^2.0",
		"laravel/pint": "^1.0",
		"mockery/mockery": "^1.0",
		"nunomaduro/collision": "^8.0",
		"orchestra/testbench": "^10.0",
		"pestphp/pest": "^4.0",
		"pestphp/pest-plugin-laravel": "^4.0"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Misaf\\VendraUser\\": "src/",
			"Misaf\\VendraUser\\Database\\Factories\\": "database/factories/",
			"Misaf\\VendraUser\\Database\\Seeders\\": "database/seeders/",
			"Misaf\\VendraUser\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true
		},
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true
	},
	"extra": {
		"laravel": {
			"providers": [
				"Misaf\\VendraUser\\Providers\\UserServiceProvider"
			]
		}
	},
	"scripts": {
		"analyse": "vendor/bin/phpstan analyse",
		"test": "pest"
	},
	"$schema": "https://getcomposer.org/schema.json"
}
